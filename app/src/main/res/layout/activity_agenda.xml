<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools"

    android:layout_width="match_parent"

    android:layout_height="match_parent"

    android:background="@drawable/bg_screen"

    android:fitsSystemWindows="true"

    tools:context=".AgendaActivity">



    <com.google.android.material.appbar.MaterialToolbar

        android:id="@+id/toolbar_agenda"

        android:layout_width="0dp"

        android:layout_height="?attr/actionBarSize"

        android:background="@color/surface_dark"

        android:elevation="4dp"

        android:minHeight="?attr/actionBarSize"

        android:theme="@style/Theme.Onecheck.Toolbar"

        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toTopOf="parent"

        app:menu="@menu/menu_agenda"

        app:title="@string/agenda_titulo"

        app:titleTextColor="@color/text_primary" />



    <TextView

        android:id="@+id/txt_agenda_subtitulo"

        android:layout_width="0dp"

        android:layout_height="wrap_content"

        android:background="@color/surface_dark"

        android:paddingStart="20dp"

        android:paddingTop="4dp"

        android:paddingEnd="20dp"

        android:paddingBottom="12dp"

        android:text="@string/agenda_subtitulo"

        android:textAppearance="@style/OnecheckTextCaption"

        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toBottomOf="@id/toolbar_agenda" />



    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout

        android:id="@+id/swipe_agenda"

        android:layout_width="0dp"

        android:layout_height="0dp"

        app:layout_constraintBottom_toBottomOf="parent"

        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintStart_toStartOf="parent"

        app:layout_constraintTop_toBottomOf="@id/txt_agenda_subtitulo">



        <FrameLayout

            android:layout_width="match_parent"

            android:layout_height="match_parent">



            <ListView

                android:id="@+id/list_vistorias"

                android:layout_width="match_parent"

                android:layout_height="match_parent"

                android:clipToPadding="false"

                android:divider="@android:color/transparent"

                android:dividerHeight="12dp"

                android:paddingStart="16dp"

                android:paddingTop="@dimen/list_padding_vertical"

                android:paddingEnd="16dp"

                android:paddingBottom="@dimen/list_padding_bottom"

                android:scrollbars="none"

                tools:listitem="@layout/item_vistoria" />



            <TextView

                android:id="@+id/txt_agenda_erro"

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:layout_gravity="center"

                android:layout_marginStart="24dp"

                android:layout_marginEnd="24dp"

                android:gravity="center"

                android:textAppearance="@style/OnecheckTextBody"

                android:textColor="@color/error_red"

                android:visibility="gone"

                tools:text="Erro ao carregar agenda"

                tools:visibility="visible" />



            <TextView

                android:id="@+id/txt_agenda_vazio"

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:layout_gravity="center"

                android:text="@string/agenda_vazio"

                android:textAppearance="@style/OnecheckTextBody"

                android:visibility="gone"

                tools:visibility="visible" />

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>



</androidx.constraintlayout.widget.ConstraintLayout>

